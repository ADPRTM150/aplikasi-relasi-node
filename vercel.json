{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|xml|txt|webp|avif|woff|woff2|ttf|eot|map)",
      "dest": "/public/$1.$2"
    },
    {
      "src": "/([^.]*)",
      "dest": "/public/$1.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ]
}